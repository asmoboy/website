{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/en/products/:slug/",
      "destination": "/api/product?lang=en&slug=:slug"
    },
    {
      "source": "/de/produkte/:slug/",
      "destination": "/api/product?lang=de&slug=:slug"
    },
    {
      "source": "/ro/produse/:slug/",
      "destination": "/api/product?lang=ro&slug=:slug"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=(), browsing-topics=(), payment=(self)"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'none'; object-src 'none'; base-uri 'self'"
        }
      ]
    }
  ]
}
